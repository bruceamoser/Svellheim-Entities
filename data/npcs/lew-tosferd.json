    {
      "name": "Smoke Bomb",
      "type": "feature",
      "_id": "LEWSMOKEBOMB0001",
      "img": "icons/magic/air/fog-gas-smoke-dense-pink.webp",
      "system": {
        "description": {
          "value": "<p>Lew can use the Hide maneuver even while observed and without cover or concealment. When he does, he shifts a number of squares equal to his Agility (3), and if he ends the shift with cover or concealment, he is automatically hidden.</p>",
          "director": "This is Lew's exit strategy. If a fight breaks out or the PCs threaten him, he vanishes. Pair with Crafty—he shifts 3 without provoking, then he's gone."
        },
        "source": {
          "book": "Heroes",
          "page": "163",

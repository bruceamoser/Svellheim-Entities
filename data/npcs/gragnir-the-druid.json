      },
      "_stats": {
        "compendiumSource": null,
        "duplicateSource": null,
        "exportSource": null,
        "coreVersion": "13.351",
        "systemId": "draw-steel",
        "systemVersion": "0.10.0",
        "createdTime": 0,
        "modifiedTime": 0,
        "lastModifiedBy": null
      },
      "type": "feature",
      "system": {
        "description": {
          "value": "<p>Gragnir can pass through any doorway, keyhole, or gap wide enough for ash to drift through. He leaves grey dustings of ash on the surfaces he passes. He cannot be pursued by normal locks or bolts. He cannot bring others with him.</p>",
          "director": "<p>Director note: This explains how Gragnir entered the locked royal chamber. He cannot pass through magical warding or sanctified barriers, only mundane locks and doors. He cannot take others through with him using this feature.</p>"
        },
        "source": {
          "book": "Svellheim Campaign (Era of Embers)",
          "page": "Beat 03",
          "license": ""
        },
        "_dsid": "through-the-cracks",

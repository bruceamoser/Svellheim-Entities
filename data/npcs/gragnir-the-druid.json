      },
      "_stats": {
        "compendiumSource": null,
        "duplicateSource": null,
        "exportSource": null,
        "coreVersion": "13.351",
        "systemId": "draw-steel",
        "systemVersion": "0.10.0",
        "createdTime": 0,
        "modifiedTime": 0,
        "lastModifiedBy": null
      },
      "type": "feature",
      "system": {
        "description": {
          "value": "<p>Gragnir speaks in compressed, ash-edged sentences. He answers questions with other questions or riddles — not to deceive, but because he considers most direct answers inadequate. He has seen this crisis coming for years and is tired of being ignored. He is not hostile, but he is not comforting.</p>",
          "director": "<p>Director note: If a hero asks Gragnir a provocative question, use the examples from the source doc: 'How did you get in here?' = 'The same way the cold gets in. Through the cracks.' 'Who are you?' = 'A man who talks to trees. The trees are dying. That should concern you.' This is a roleplay cue, not a mechanical effect.</p>"
        },
        "source": {
          "book": "Svellheim Campaign (Era of Embers)",
          "page": "Beat 03",
          "license": ""
        },
        "_dsid": "ash-walkers-manner",
        "advancements": {},
        "prerequisites": {
          "value": "",
          "dsid": [],
          "level": null
        }
      },
      "_id": "h2cSB3CtVFz3f5Xa"
    }

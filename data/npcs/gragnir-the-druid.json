          "level": null
        }
      },
      "_id": "awq6bBAdJhrRtiCa"
    },
    {
      "name": "The Ash-Walker's Manner",
      "img": "icons/magic/nature/leaf-ash-silhouette-gray.webp",
      "effects": [],
      "flags": {},
      "folder": null,
      "sort": 0,
      "ownership": {

    {
      "name": "Judgement",
      "type": "ability",
      "img": "icons/skills/targeting/crosshair-bars-yellow.webp",
      "system": {
        "source": {
          "book": "Heroes",
          "page": "80",
          "license": "Draw Steel Creator License"
        },
        "_dsid": "judgement",
        "story": "You utter a prayer that outlines your foe in holy energy.",
        "keywords": [
          "magic",
          "ranged"
        ],
        "type": "maneuver",
        "category": "signature",
        "resource": null,
        "trigger": "",
        "distance": {

      "type": "feature",
      "img": "icons/magic/perception/eye-ringed-glow-angry-red.webp",
      "system": {
        "description": {
          "value": "<p>The Wight-Lord can sense living creatures within 10 squares regardless of concealment or invisibility.</p>",
          "director": "<p>This prevents stealth-based approaches from trivializing the encounter. The Wight-Lord always knows where the living are.</p>"

    {
      "name": "Lord of the Barrow",
      "type": "feature",
      "img": "icons/magic/death/undead-skeleton-worn-blue.webp",
      "system": {
        "description": {
          "value": "<p>All allied undead within 5 squares gain +1 to damage rolls and cannot be turned or banished while the Wight-Lord lives.</p>",
          "director": "<p>This aura makes even Draugr Thralls more threatening. Position the Wight-Lord centrally on the wall to maximize coverage. The anti-banishment clause prevents Kaelen's ember-mark from being used to simply dismiss the undead.</p>"
        },
        "source": {
          "book": "Svellheim Campaign (Era of Embers)",
          "page": "",
